{
  "name": "@timbal-ai/blueprint-ui",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "description": "Blueprint UI template for building AI applications with React, Vite, and the Timbal SDK",
  "author": "Timbal <team@timbal.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/timbal-ai/blueprint-ui"
  },
  "homepage": "https://timbal.ai",
  "scripts": {
    "dev": "vite",
    "dev:linked": "node ../timbal-react/scripts/dev-linked.mjs vite",
    "prebuild": "find src -name '.nfs*' -delete 2>/dev/null || true",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "dna:compile": "timbal-dna compile",
    "dna:check": "timbal-dna check",
    "dna:registries": "timbal-dna registries",
    "registry:build": "node scripts/build-registry.mjs",
    "smoke:screenshots": "node scripts/screenshot-smoke.mjs"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.10",
    "@assistant-ui/react-markdown": "^0.12.3",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-table": "^8.21.3",
    "@timbal-ai/timbal-react": "^4.2.1",
    "@timbal-ai/timbal-sdk": "^0.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "embla-carousel-react": "^8.6.0",
    "katex": "^0.16.28",
    "lucide-react": "^1.14.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "nucleo-ui-outline-18": "^1.5.0",
    "radix-ui": "^1.6.2",
    "react": "^19.2.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.0",
    "react-resizable-panels": "^2.1.9",
    "react-router-dom": "^7.9.6",
    "recharts": "^3.9.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2"
  }
