{
  "name": "@timbal-ai/blueprint-ui",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "description": "Blueprint UI template for building AI applications with React, Vite, and the Timbal SDK",
  "author": "Timbal <team@timbal.ai>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/timbal-ai/blueprint-ui"
  },
  "homepage": "https://timbal.ai",
  "scripts": {
    "dev": "vite",
    "dev:linked": "node ../timbal-react/scripts/dev-linked.mjs vite",
    "prebuild": "find src -name '.nfs*' -delete 2>/dev/null || true",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.10",
    "@assistant-ui/react-markdown": "^0.12.3",
    "@tailwindcss/vite": "^4.1.17",
    "@timbal-ai/timbal-react": "^0.8.0",
    "@timbal-ai/timbal-sdk": "^0.6.3",
    "clsx": "^2.1.1",
    "katex": "^0.16.28",
    "lucide-react": "^1.14.0",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.4",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.2"
  }
}
