# App
VITE_APP_TITLE=Blueprint UI
# Dev server port (default 5173)
# VITE_APP_PORT=5173

# Timbal — set VITE_TIMBAL_PROJECT_ID to enable auth (SessionProvider / AuthGuard)
# VITE_TIMBAL_BASE_URL=https://api.timbal.ai
# VITE_TIMBAL_API_KEY=
# VITE_TIMBAL_ORG_ID=
# VITE_TIMBAL_PROJECT_ID=

# Optional welcome copy on the chat screen
# VITE_WELCOME_HEADING=
# VITE_WELCOME_SUBHEADING=

# Dev: proxy /api to your backend (see vite.config.ts)
# VITE_API_PROXY_TARGET=http://localhost:3000

# Floating workforce sidebar (TimbalStudioShell). Default: off (TimbalChatShell).
# VITE_STUDIO_SIDEBAR=true

# App kit expansion sample at /demo/app-kit (AppShell + Page + floating AppCopilot).
# VITE_APP_KIT_DEMO=true

# Component gallery at /gallery (dev/CI screenshot smoke surface).
# VITE_GALLERY=true

# Theming: src/design/dna.json -> `bun run dna:compile` (no env flag).
