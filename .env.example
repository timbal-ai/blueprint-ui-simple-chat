# App
VITE_APP_TITLE=Blueprint UI
# Dev server port (default 5173)
# VITE_APP_PORT=5173

# Timbal — set VITE_TIMBAL_PROJECT_ID to enable auth (SessionProvider / AuthGuard)
# VITE_TIMBAL_BASE_URL=https://api.timbal.ai
# VITE_TIMBAL_API_KEY=
# VITE_TIMBAL_ORG_ID=
# VITE_TIMBAL_PROJECT_ID=

# Optional welcome copy on the chat screen
# VITE_WELCOME_HEADING=
# VITE_WELCOME_SUBHEADING=

# Dev: proxy /api to your backend (see vite.config.ts)
# VITE_API_PROXY_TARGET=http://localhost:3000
